{
  "name": "claude-test-bench",
  "version": "1.0.0",
  "type": "module",
  "description": "A test bench for evaluating Claude agent configurations",
  "main": "dist/server/index.js",
  "bin": {
    "ctb": "./dist/bin/ctb.js",
    "claude-test-bench": "./dist/bin/ctb.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "dev": "tsc -p tsconfig.server.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Z-M-Huang/claude-test-bench.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Z-M-Huang/claude-test-bench/issues"
  },
  "homepage": "https://github.com/Z-M-Huang/claude-test-bench#readme",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "express": "^5.1.0",
    "open": "^10.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
