{
  "name": "model-test-bench",
  "version": "1.0.1",
  "type": "module",
  "description": "Benchmark LLM behavior — compare models, test system prompts, and grade runs with LLM-based evaluation",
  "main": "dist/server/index.js",
  "bin": {
    "mtb": "./dist/bin/mtb.js",
    "model-test-bench": "./dist/bin/mtb.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "!dist/**/*.test.*",
    "!dist/**/route-test-helpers.*",
    "docs/schemas/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.server.json && tsc -p tsconfig.bin.json",
    "build:web": "vite build",
    "dev": "tsc -p tsconfig.server.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Z-M-Huang/model-test-bench.git"
  },
  "keywords": [
    "model",
    "ai-model",
    "benchmark",
    "testing",
    "ai-agent",
    "llm",
    "evaluation",
    "ai-sdk",
    "instruction-compliance",
    "model-testing"
  ],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Z-M-Huang/model-test-bench/issues"
  },
  "homepage": "https://github.com/Z-M-Huang/model-test-bench#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.54",
    "@ai-sdk/openai": "^3.0.49",
    "ai": "^6.0.142",
    "express": "^5.1.0",
    "open": "^10.1.0",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "postcss": "^8.5.8",
    "prettier": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.1.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
