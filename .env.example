# Claude Test Bench - Environment Configuration
# Copy this to .env and fill in your values.
# Only ONE of Option 1 or Option 2 is needed.

# ─── Option 1: API Provider ───────────────────────────────────────────
# Works with Anthropic or any Anthropic-compatible endpoint (MiniMax, etc.)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Model ID sent to the provider. All ANTHROPIC_DEFAULT_*_MODEL env vars
# are set to this value, so the SDK always uses exactly this model.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Option 2: OAuth Token ────────────────────────────────────────────
# For Claude Code OAuth-based access
# CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_MODEL=claude-sonnet-4-6
