# Model Test Bench - Environment Configuration
# Copy this to .env and fill in your values.
# Providers are configured in the web UI, but you can set defaults here.

# ─── Anthropic ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI ──────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─── Google ──────────────────────────────────────────────────────────
# GOOGLE_GENERATIVE_AI_API_KEY=...
